# Production env template for the ELPC Outline fork on a Duke VM.
#
# Copy to .env on the VM and fill in the <...> values:   cp .env.production.sample .env
# Used by docker-compose.prod.yml (which sets DATABASE_URL / REDIS_URL for you).
# See .env.sample for the full list of optional variables and their docs.

NODE_ENV=production

# The VM's real public https hostname (no trailing slash). Must match the OIDC
# redirect URI you register at Duke: <URL>/auth/oidc.callback
URL=https://outline.CHANGE_ME.duke.edu
PORT=3000

# App is behind the nginx TLS proxy.
FORCE_HTTPS=true
# Don't phone home (update check / anonymized stats).
ENABLE_UPDATES=false

# ––– Secrets (generate with `openssl rand -hex 32`) –––
# SECRET_KEY must be exactly 64 hex chars and must NOT change once set, or all
# existing logins are invalidated.
SECRET_KEY=
UTILS_SECRET=
# Postgres password — docker-compose.prod.yml uses this for BOTH the postgres
# container and the app's DATABASE_URL. Do NOT set DATABASE_URL / REDIS_URL here.
DATABASE_PASSWORD=

# ––– File storage (uploaded PDFs/attachments live on a docker volume) –––
FILE_STORAGE=local
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000

# ––– AI features: Duke LiteLLM proxy –––
# Hybrid semantic search + Ask AI + summarize. Model ids use DASHES (gpt-5.5),
# not dots. text-embedding-3-large is auto-truncated to the column's 1536 dims.
SEARCH_PROVIDER=vector
LITELLM_BASE_URL=
LITELLM_API_KEY=
LITELLM_SUMMARY_MODEL=gpt-5.5
LITELLM_ANSWER_MODEL=gpt-5.5
LITELLM_EMBEDDING_MODEL=text-embedding-3-large

# ––– Sign-in: Duke NetID (OIDC) –––
# Register a client at https://authentication.oit.duke.edu/manager with redirect
# URI <URL>/auth/oidc.callback, then paste the client id/secret below. No SMTP is
# needed for sign-in. After first sign-in (first user = admin), enable
# "Require invites" in Settings → Security to allowlist members.
OIDC_ISSUER_URL=https://oauth.oit.duke.edu/oidc/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISPLAY_NAME=Duke NetID
OIDC_USERNAME_CLAIM=preferred_username
OIDC_SCOPES=openid profile email
